<mxfile host="app.diagrams.net">
  <diagram name="Database Design" id="dailypaper-db">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- User Document -->
        <mxCell id="user-header" value="User (collection: users)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;fontSize=14;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="40" y="40" width="300" height="200" as="geometry" />
        </mxCell>
        <mxCell id="user-fields" value="id: ObjectId (PK)&#xa;username: str (unique, indexed)&#xa;email: str (unique, indexed)&#xa;hashed_password: str&#xa;newspaper_name: str&#xa;created_at: datetime&#xa;updated_at: datetime" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="50" y="80" width="280" height="150" as="geometry" />
        </mxCell>

        <!-- Page Document -->
        <mxCell id="page-header" value="Page (collection: pages)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=14;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="420" y="40" width="300" height="200" as="geometry" />
        </mxCell>
        <mxCell id="page-fields" value="id: ObjectId (PK)&#xa;name: str&#xa;slug: str (indexed)&#xa;user_id: str (indexed)&#xa;display_order: int&#xa;created_at: datetime&#xa;updated_at: datetime&#xa;&#xa;Index: (user_id, slug) unique" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="430" y="80" width="280" height="150" as="geometry" />
        </mxCell>

        <!-- PageContent Document -->
        <mxCell id="pc-header" value="PageContent (collection: page_contents)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;fontSize=14;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="800" y="40" width="360" height="220" as="geometry" />
        </mxCell>
        <mxCell id="pc-fields" value="id: ObjectId (PK)&#xa;user_id: str (indexed)&#xa;page_slug: str&#xa;edition_date: date&#xa;headline: str (optional)&#xa;stories: [Story] (embedded)&#xa;created_at: datetime&#xa;updated_at: datetime&#xa;&#xa;Index: (user_id, page_slug, edition_date) unique" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="810" y="80" width="340" height="170" as="geometry" />
        </mxCell>

        <!-- Story Embedded Model -->
        <mxCell id="story-header" value="Story (embedded in PageContent)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=1;fontSize=14;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="800" y="320" width="360" height="200" as="geometry" />
        </mxCell>
        <mxCell id="story-fields" value="id: str (UUID)&#xa;title: str&#xa;body: str&#xa;image_key: str (optional)&#xa;link: str (optional)&#xa;priority: str (high | medium | low)&#xa;position: int" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="810" y="360" width="340" height="150" as="geometry" />
        </mxCell>

        <!-- Composition arrow: PageContent -> Story -->
        <mxCell id="pc-story-rel" style="endArrow=diamondThin;endFill=1;strokeWidth=2;" edge="1" parent="1" source="pc-header" target="story-header">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="pc-story-label" value="embeds 0..*" style="edgeLabel;html=1;fontSize=11;" vertex="1" connectable="0" parent="pc-story-rel">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Association: User -> Page -->
        <mxCell id="user-page-rel" style="endArrow=open;strokeWidth=2;dashed=1;" edge="1" parent="1" source="user-header" target="page-header">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="user-page-label" value="user_id" style="edgeLabel;html=1;fontSize=11;" vertex="1" connectable="0" parent="user-page-rel">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Association: User -> PageContent -->
        <mxCell id="user-pc-rel" style="endArrow=open;strokeWidth=2;dashed=1;" edge="1" parent="1" source="user-header" target="pc-header">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="user-pc-label" value="user_id" style="edgeLabel;html=1;fontSize=11;" vertex="1" connectable="0" parent="user-pc-rel">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Association: Page -> PageContent -->
        <mxCell id="page-pc-rel" style="endArrow=open;strokeWidth=2;dashed=1;" edge="1" parent="1" source="page-header" target="pc-header">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="page-pc-label" value="page_slug" style="edgeLabel;html=1;fontSize=11;" vertex="1" connectable="0" parent="page-pc-rel">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
