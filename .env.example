MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=dailypaper
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080
UPLOAD_DIR=./uploads

# Email / SMTP (Gmail — for password reset emails)
# SMTP_EMAIL=your-email@gmail.com
# SMTP_APP_PASSWORD=your-app-password
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# PASSWORD_RESET_EXPIRE_MINUTES=60

# Frontend base URL (used in password reset email links)
FRONTEND_BASE_URL=http://localhost:8098

# Google OAuth (optional — enables "Sign in with Google")
# GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
